                        </asp:DropDownList>
                    </td>
                    <td>
                        <label>
                            <%=Resources.Resource.CanalDistribuicao %>:</label>
                    </td>
                    <td>
                        <asp:DropDownList ID="ddCanalDistribuicao" runat="server">
                            <asp:ListItem Value="RE" Selected="True" Text="<%$ Resources:Resource, Retalho %>"></asp:ListItem>
                        </asp:DropDownList>
                    </td>
                </tr>
                <tr>
