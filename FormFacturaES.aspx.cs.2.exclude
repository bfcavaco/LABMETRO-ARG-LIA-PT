        //=================================================================================================
        //BOTÃO PARA CRIAÇÃO DOS FICHEIROS PARA O SAP -- NOVO
        //=================================================================================================
        private void btnFicheiro_Click(object sender, System.EventArgs e)
        {
            if (this.txtNumClienteSAP.Text == "" && this.ddCondPagamentoFactura.SelectedValue != "1") //a rigor, para pronto pagamento n precisa 
            //de ter numero de cliente sap.
            {
                this.lblMessage.Text = "Empresa sem Núm. Cliente SAP. Actualize a empresa antes de gerar a ordem de venda.";
            }
            else if (this.ddCondPagamentoFactura.SelectedValue == "1") //pronto pagamento
            {
                this.lblMessage.Text = "Não pode gerar ordens de venda para facturas com pronto pagamento.";
            }

            else
            {
                //retorna true ou false e faz o response redirect depois aqui, senao causa um erro:
                //14:31:44.9049179- System.Threading.ThreadAbortException: Thread was being aborted.
                if (writeAxaptaFile(this.ViewState["idFactura"].ToString()))
                {
                    this.Response.Redirect("FormFacturaES.aspx?btn=FAC&id=" + this.ViewState["idFactura"].ToString(), true);
                }
            }
        }

