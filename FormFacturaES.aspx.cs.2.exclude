        //=================================================================================================
        //INSERE OS DADOS DA FACTURA NA BD
        //No insert da factura, a data da factura assume o valor da data actual (getdate()); 
        //a data depois é actualizada apenas na criação das ordens de venda. 
        //assume a data do proprio dia ou do dia seguinte, conforme a hora do dia em que a operação é				efectuada
        //com a hipotese de poder forçar a data.... 
        //=================================================================================================
        private void InsertBD()
        {

            string idFactura;
            string id;

            DTDestino = (DataTable)this.ViewState["DTDestino"];

            if (DTDestino.Rows.Count == 0) 
            {
                this.lblMessage.Text = "Tem de inserir pelo menos uma linha na factura.";
            }
            else
            {
                //if (!this.validaRegiaoVendas(DTDestino))
                //{
                //    this.lblMessage.Text = "Existem calibrações externa. Actualize a região de vendas da empresa.<br>e carregue no botão 'Actualizar Região' para gravar as alterações.";
                //}
                //else
                //{
                    this.calculaValorTotalFactura(); // só para garantir que o total está bem actualizado

                    DATA.FacturaData factura = new LabMetro.DATA.FacturaData();

                    idFactura = factura.InsertFacturaWithLinhas(this.ddBRE.SelectedValue.ToString(), this.ddEmpresa.SelectedValue.ToString(), this.txtValorDespesasEnvio.Text, this.txtValorAjudasCustoDeslocacoes.Text, this.txtValorTotalFactura.Text, this.txtObservacoes.Text, User.Identity.Name.ToString(), DTDestino, this.ddTipoDocumento.SelectedValue.ToString(), this.ddCanalDistribuicao.SelectedValue, this.ddEscritorioVendas.SelectedValue, this.ddCondPagamentoFactura.SelectedValue,null).ToString(); //Não juntar estas linhas
                    //senao entra 2 vezes na mesma função. 
                    id = idFactura;

                    if (id == "0")
                    {
                        lblMessage.Text = GERAL.clsGeral.ErrorMessage.ERR_INSERT;
                    }
                    else
                    {
                        //this.Server.Transfer("FormFacturaSAP.aspx?btn=FAC&id=" + id,false);  //Deixar a false senao entra - nao sei porquê - novamente na função insertfacturawithlinha e dps dá erro.
                        this.Response.Redirect("FormFacturaES.aspx?btn=FAC&id=" + idFactura, true);
                        //deixar assim, sem server transfer
                    }
                    factura = null;
                //}
            }
        }

        //=================================================================================================
        //ACTUALIZA OS DADOS DA FACTURA NA BD
        //=================================================================================================
        private void UpdateBD()
        {
            DTDestino = (DataTable)this.ViewState["DTDestino"];
            DTOrigem = (DataTable)this.ViewState["DTOrigem"];

            //if (DTDestino.Rows.Count == 0)
            //{
            //    this.lblMessage.Text = "Tem de inserir pelo menos uma linha na factura.";
            //}
            //else
            //{

                //if (!this.validaRegiaoVendas(DTDestino))
                //{
                //    this.lblMessage.Text = "Existem calibrações externa. Actualize a região de vendas da empresa.<br>e carregue no botão 'Actualizar Região' para gravar as alterações.";
                //}
                //else
                //{
                    DATA.FacturaData factura = new LabMetro.DATA.FacturaData();

                    string idFactura = this.ViewState["idFactura"].ToString();

                    int retvalue = factura.UpdateFacturaWithLinhas(this.ViewState["idFactura"].ToString(), this.txtValorDespesasEnvio.Text.ToString(), this.txtValorAjudasCustoDeslocacoes.Text.ToString(), this.txtValorTotalFactura.Text.ToString(), this.txtObservacoes.Text.ToString(), User.Identity.Name.ToString(), DTOrigem, DTDestino, this.ddTipoDocumento.SelectedValue, this.ddCanalDistribuicao.SelectedValue, this.ddEscritorioVendas.SelectedValue, this.ddCondPagamentoFactura.SelectedValue, this.ViewState["idModif"].ToString(), null);

                    if (retvalue == 0)
                    {
                        lblMessage.Text = GERAL.clsGeral.ErrorMessage.ERR_UPDATE;
                    }
                    else
                    {
                        lblMessage.Text = GERAL.clsGeral.ErrorMessage.MSG_UPDATE_DB;
                        //colocar a nova dtAlteração em viewstate
                        try
                        {
                            string strSQL = "SELECT idUtilAlteracao FROM FACTURA where idFactura = " + this.ViewState["idFactura"].ToString();
                            string id = Convert.ToString(GERAL.clsDataAccess.myExecuteScalar(strSQL));

                            this.ViewState["idModif"] = id;
                        }
                        catch (Exception ex)
                        {
                            GERAL.clsWriteError.WriteLog(ex);
                        }
                    }

                    factura = null;
                //}
            //}
        }



