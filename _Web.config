  <!--atenção a nova connectionstring está aqui.-->
  <connectionStrings>
    <add name="connstr" connectionString="Server=CLDDEV02\SQLEXPRESS;DataBase=weblabmetrodzdev;User ID=LabMetro;Password=edfh+178;Trusted_Connection=False;Min Pool Size=5; Max Pool Size=100; Connect Timeout=20" providerName="System.Data.SqlClient" />
    <add name="ConnectionString" connectionString="Data Source=CLDDEV02\SQLEXPRESS;Persist Security Info=True;User ID=LabMetro;Password=edfh+178" providerName="System.Data.SqlClient" />
    <add name="ANG_LABMETROConnectionString" connectionString="Data Source=CLDDEV02\SQLEXPRESS;Initial Catalog=weblabmetrodzdev;User ID=Labmetro;Password=edfh+178" providerName="System.Data.SqlClient" />
  </connectionStrings>
  
  <!-- CAMINHO PARA O FICHEIRO DE LOGs -->
	<system.web>
		<!-- disable session state for application -->
		<!-- debug a false em producao -->
    <pages validateRequest="true" styleSheetTheme="myTheme">
      <controls>
        <add tagPrefix="asp" namespace="System.Web.UI" assembly="System.Web.Extensions, Version=1.0.61025.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" />
      </controls>
    </pages>
   
		<httpRuntime executionTimeout="600" appRequestQueueLimit="100" />
		<compilation defaultLanguage="c#" debug="false">
      <assemblies>
        <add assembly="System.Web.Extensions, Version=1.0.61025.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" />
      </assemblies>
		</compilation>
		<customErrors mode="Off" defaultRedirect="PagErro.aspx" />
		
    <!-- enable Forms authentication -->
		<authentication mode="Forms">
			
    <!-- name : o nome do cookie-->
		<forms name=".LABMAUTH" loginUrl="Default.aspx" protection="All" path="/" timeout="40" />
		</authentication>
		<trace enabled="false" requestLimit="10" pageOutput="true" traceMode="SortByCategory" localOnly="true" />
		<sessionState mode="InProc" stateConnectionString="tcpip=127.0.0.1:42424" sqlConnectionString="data source=127.0.0.1;Trusted_Connection=yes" cookieless="false" timeout="40" />
		<globalization requestEncoding="utf-8" responseEncoding="utf-8" culture="pt-PT" uiCulture="pt-PT" />
    <httpHandlers>
      <remove verb="*" path="*.asmx" />
      <add verb="*" path="*.asmx" validate="false" type="System.Web.Script.Services.ScriptHandlerFactory, System.Web.Extensions, Version=1.0.61025.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" />
      <add verb="*" path="*_AppService.axd" validate="false" type="System.Web.Script.Services.ScriptHandlerFactory, System.Web.Extensions, Version=1.0.61025.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" />
      <add verb="GET,HEAD" path="ScriptResource.axd" type="System.Web.Handlers.ScriptResourceHandler, System.Web.Extensions, Version=1.0.61025.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" validate="false" />
    </httpHandlers>
    <xhtmlConformance mode="Transitional" />
    <httpModules>
      <add name="ScriptModule" type="System.Web.Handlers.ScriptModule, System.Web.Extensions, Version=1.0.61025.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" />
    </httpModules>
	</system.web>
  <system.web.extensions>
    <scripting>
      <webServices>
        <jsonSerialization maxJsonLength="800000" />
      </webServices>
    </scripting>
  </system.web.extensions>
    <system.webServer>
        <defaultDocument>
            <files>
                <remove value="Default.htm" />
                <remove value="iisstart.htm" />
                <remove value="index.html" />
                <remove value="index.htm" />
                <add value="Default.aspx" />
            </files>
        </defaultDocument>
        <directoryBrowse enabled="false" />
    </system.webServer>
