                        <label>
                            <%=Resources.Resource.EscritorioVendas %>:</label>
                    </td>
                    <td>
                        <asp:DropDownList ID="ddEscritorioVendas" runat="server">
                        </asp:DropDownList>
                    </td>
                    <td>
                        <label>
                            <%=Resources.Resource.CondicoesPagamento %>:</label>
                    </td>
