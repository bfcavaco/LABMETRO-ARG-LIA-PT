<?xml version="1.0" encoding="utf-8" ?>
<xs:schema id="DSEquipamentoACalibrar" targetNamespace="http://tempuri.org/DSEquipamentoACalibrar.xsd"
	elementFormDefault="qualified" attributeFormDefault="qualified" xmlns="http://tempuri.org/DSEquipamentoACalibrar.xsd"
	xmlns:mstns="http://tempuri.org/DSEquipamentoACalibrar.xsd" xmlns:xs="http://www.w3.org/2001/XMLSchema"
	xmlns:msdata="urn:schemas-microsoft-com:xml-msdata">
	<xs:element name="DSEquipamentoACalibrar" msdata:IsDataSet="true">
		<xs:complexType>
			<xs:choice maxOccurs="unbounded">
				<xs:element name="dtEquipamentoACalibrar">
					<xs:complexType>
						<xs:sequence>
							<xs:element name="empresa" type="xs:string" />
							<xs:element name="numIdentificacao" type="xs:string" minOccurs="0" />
							<xs:element name="idGrandeza" type="xs:string" />
							<xs:element name="grandeza" type="xs:string" />
							<xs:element name="tipoEquipamento" type="xs:string" />
							<xs:element name="marca" msdata:ReadOnly="true" type="xs:string" minOccurs="0" />
							<xs:element name="modelo" type="xs:string" minOccurs="0" />
							<xs:element name="periodicidadeCalibracao" type="xs:short" minOccurs="0" />
							<xs:element name="dtUltimaCalibracao" type="xs:dateTime" minOccurs="0" />
							<xs:element name="dtProximaCalibracao" msdata:ReadOnly="true" type="xs:dateTime" minOccurs="0" />
							<xs:element name="calibInt" type="xs:string" minOccurs="0" />
							<xs:element name="EmpresaManutencao" type="xs:string" minOccurs="0" />
						</xs:sequence>
					</xs:complexType>
				</xs:element>
			</xs:choice>
		</xs:complexType>
	</xs:element>
</xs:schema>