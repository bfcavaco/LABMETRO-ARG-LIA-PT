        private void Page_Load(object sender, System.EventArgs e)
        {
            this.lblMessage.Text = "";
            this.lblErroRequisicoes.Text = "";

            Hashtable ht = (Hashtable)this.Session["HTPermissions"];
            if (ht == null) //session expired
            {
                this.Server.Transfer("Default.aspx?err=2", false);
            }
            else
            {
                if (!ht.ContainsKey(ID_PAG))
                {
                    this.Server.Transfer("Default.aspx?err=1", false);
                }
                else
                {
                    int intAcesso = System.Convert.ToInt32(ht[ID_PAG]);

                    if (intAcesso == 0)
                    {
                        this.btnSubmit.Enabled = false;
                        this.btnReset.Enabled = false;
                    }

                    if (!this.Page.IsPostBack)
                    {

                        if (this.Request.QueryString["id"] != null)
                        {
                            this.btnSubmit.CommandArgument = "update";

                            if (this.Request.QueryString["id"] != "")
                            {
                                this.ViewState["idFactura"] = this.Request.QueryString["id"].ToString();
                                
                                this.fillForm(this.ViewState["idFactura"].ToString());
                                this.fillEmpresaContratanteDoBRE(); //isto ja foi chamado no filldata... nao sei pq está aqui de novo.


                                //this.fillCodigoBloqueio(); a fazer: codigo bloqueio e condições pagamento da empresa
                                
                                this.fillEmpresaDevedora(); //prenche os dados devedores da empresa ou empresa contratante
                            }
                        }
                        //form vazio
                        else
                        {
                            this.ViewState["idFactura"] = null;

                            this.btnSubmit.CommandArgument = "insert";

                            this.fillEmpresas(); //preenche empresas
                            this.fillBREs(); //preenche bre's
                            
                            this.fillEmpresaContratanteDoBRE(); //preenche empresas contratantes
                           
                            this.fillEmpresaDevedora(); //preenche se empresa ou emp.cont. é devedora

                            this.setFacturaData(); //para inicializar alguns campos a 0
                            this.btnFicheiro.Enabled = false; //factura n está inserida, n se pode criar ficheiro
                            this.btnVerFactura.Enabled = false;
                        }

                        //para a ordenacao do datagrid de origem
                        this.ViewState["sortField"] = "codTipoEquipamento";
                        this.ViewState["sortDirection"] = "DESC";

                        this.ViewState["sortFieldDestino"] = "codTipoEquipamento";
                        this.ViewState["sortDirectionDestino"] = "DESC";

                        this.ViewState["sortFieldReq"] = "idRequisicao";
                        this.ViewState["sortDirectionReq"] = "DESC";
                        //==============================================

                        this.CreateDataSource();
                        this.BindGridSource();
                        try
                        {
                            this.CreateDataSourceDTDestino();
                            this.BindGridDestino();
                        }
                        catch (Exception ex)
                        {
                            //this.Response.Write(ex.ToString()); 
                            GERAL.clsWriteError.WriteLog(ex);
                        }
                    }
                    //==================================================
                }
            }


        }

        //*************************************************************************************************
        //FUNÇÕES ASSOCIADAS AOS DOIS DATAGRIDS PRINCIPAIS, ORIGEM E DESTINO.
