        private void refillAllData()
        {
           // this.fillDDsSAP(); //isto talvez nao seja preciso
            this.fillBREs();
           
            this.fillEmpresaContratanteDoBRE();
            this.fillEmpresaData_SAP();
            this.fillEmpresaDevedora();

            this.setFacturaData();
