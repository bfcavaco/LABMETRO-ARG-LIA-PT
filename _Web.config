		<!-- numero de peças a partir do qual é aplicado o desconto na facturação, caso o desconto seja aplicável -->
		<add key="NUMPECASPARADESCONTO" value="5"></add>
		<!-- campo "TO" para envio de FAX atraves do serviço de email -->
		<!-- dentro do codigo o 000 (3 zeros) serao substituidos pelo numero de fax do destinatário -->
		<add key="NUMFAX" value="IMCEAFAX-000@isq.pt"></add>
		<!-- ip do servidor utilizado no envio de fax por email-->
		<add key="IPSERVIDORMAIL" value="188.93.230.95"></add>
		<!-- as confirmações de envio de fax teem de ser entregues a alguem, esse alguem é definido nas proximes chaves -->
		<add key="MAIL_CONFIRMATION_FAXAVISO" value="recepcao@isq.pt"></add>
		<add key="MAIL_CONFIRMATION_ORCAMENTO" value="labmetro@isq.pt"></add>
		<add key="ID_RESP_TEC_DEFAULT_ORCAM" value="15"></add>

		<add key="canUpdatePagAtraso" value="admin" />
		<add key="canUpdateContactoInfo" value="admin,acfalcato" />
    <add key="versaoAplicacao" value="ISQapave Labmetro Angola" />
    <add key="nomeAplicacao" value="ISQapave Labmetro" />
