            {
                case "ASC":
                    this.ViewState["sortDirectionDestino"] = "DESC";
                    break;
                case "DESC":
                    this.ViewState["sortDirectionDestino"] = "ASC";
                    break;
            }

            this.ViewState["sortFieldDestino"] = e.SortExpression;
            this.BindGridDestino();
        }

