        }

        //=========================================================================================
        //Fillform - recebe o id da factura e vai buscar os dados da factura
        //=========================================================================================
        private void fillForm(string id)
        {

            LabMetro.DATA.FacturaData factura = new LabMetro.DATA.FacturaData(); //new LabMetro.DATA.FacturaData(); 

            DataTable FacturaDT = factura.DTFacturaDetails(id);
            if (FacturaDT.Rows.Count > 0)
            {
                string datatFactura = FacturaDT.Rows[0]["dtFactura"].ToString();
                if (datatFactura != "") datatFactura = GERAL.clsGeral.ToShortDate(datatFactura);

                this.txtDtFactura.Text = datatFactura;

                this.txtObservacoes.Text = FacturaDT.Rows[0]["observacoes"].ToString();
                this.txtRefFactura.Text = FacturaDT.Rows[0]["refFactura"].ToString();
                this.txtFicheiro.Text = FacturaDT.Rows[0]["idFactura"].ToString();
                this.txtValorAjudasCustoDeslocacoes.Text = FacturaDT.Rows[0]["valorAjudasCustoDeslocacoes"].ToString();
                this.txtValorDespesasEnvio.Text = FacturaDT.Rows[0]["valorDespesasEnvio"].ToString();

                string idEmpresa = FacturaDT.Rows[0]["idEmpresa"].ToString();
                string nomeEmpresa = FacturaDT.Rows[0]["nomeEmpresa"].ToString();

                //try
                //{
                //    this.ddEmpresa.SelectedValue = idEmpresa; 
                //}
                //catch
                //{
                this.ddEmpresa.Items.Insert(0, new ListItem(nomeEmpresa, idEmpresa));
                this.ddEmpresa.SelectedValue = idEmpresa;
                //}


                //isto é preenhcido dps do fillform e dps de preenchida a empresa contratante!!!!
               // this.fillEmpresaData_SAP(); //preenche os dados SAP da empresa ou empresa contratante
               // this.fillEmpresaDevedora(); //preenche se empresa ou emp.cont. é devedora



                this.ddEmpresa.Enabled = false;

                string idBRE = FacturaDT.Rows[0]["idBRE"].ToString();
                string refBRE = FacturaDT.Rows[0]["refBRE"].ToString();
                //try
                //{
                //    this.ddBRE.SelectedValue = idBRE;
                //}
                //catch
                //{
                this.ddBRE.Items.Insert(0, new ListItem(refBRE, idBRE));
                this.ddBRE.SelectedValue = idBRE;
                //}

                this.ddBRE.Enabled = false;

               
                string idTipoDocumento = FacturaDT.Rows[0]["idTipoDocumento"].ToString();
                string chCanalDistribuicao = FacturaDT.Rows[0]["chCanalDistribuicao"].ToString();
                string idEscritorioVendas = FacturaDT.Rows[0]["idEscritorioVendas"].ToString();
                string idCondicoesPagamento = FacturaDT.Rows[0]["idCondicoesPagamento"].ToString();

                string descCodigoTipoDocumento = FacturaDT.Rows[0]["descCodigoTipoDocumento"].ToString();
                string descCodigoCondPagam = FacturaDT.Rows[0]["descCodigoCondPagam"].ToString();
                string descCodigoEscritVendas = FacturaDT.Rows[0]["descCodigoEscritVendas"].ToString();

                try
                {
                    this.ddTipoDocumento.SelectedValue = idTipoDocumento;
                }
                catch
                {
                    this.ddTipoDocumento.Items.Insert(0, new ListItem(descCodigoTipoDocumento, idTipoDocumento));
                    this.ddTipoDocumento.SelectedValue = idTipoDocumento;
                }

                this.ddCanalDistribuicao.SelectedValue = chCanalDistribuicao;

                try
                {
                    this.ddEscritorioVendas.SelectedValue = idEscritorioVendas;
                }
                catch
                {
                    this.ddEscritorioVendas.Items.Insert(0, new ListItem(descCodigoEscritVendas, idEscritorioVendas));
                    this.ddEscritorioVendas.SelectedValue = idEscritorioVendas;
                }

                try
                {
                    this.ddCondPagamentoFactura.SelectedValue = idCondicoesPagamento;
                }
                catch
                {
                    this.ddCondPagamentoFactura.Items.Insert(0, new ListItem(descCodigoCondPagam, idCondicoesPagamento));
                    this.ddCondPagamentoFactura.SelectedValue = idCondicoesPagamento;
                }

                this.ViewState["idModif"] = FacturaDT.Rows[0]["idUtilAlteracao"];

                string intVersaoFicheiro = FacturaDT.Rows[0]["intVersaoFicheiro"].ToString();

                this.txtVersao.Text = intVersaoFicheiro.ToString();

                if (intVersaoFicheiro.ToString() == "0")
                {
                    this.txtFicheiro.Text = "";
                }
                else
                {
                    string nomeFicheiro = id + "_" + intVersaoFicheiro.ToString() + ".txt";
                    this.txtFicheiro.Text = nomeFicheiro;
                }
            }
        }

