		<!-- DADOS PARA A CERTIFICAÇÃO, CAMINHO E PASSWORD DO CERTIFICADO E TEXTO A COLOCAR NO CERTIFICADO -->
		<!-- É NECESSÁRIO USAR UM CAMINHO ABSOLUTO -->
		<add key="CAMINHO_CERTIFICADO" value="c:\Inetpub\wwwroot\labmetroang.isq.pt\UPLOADS\CERTIFICADOS\CERTIFICADO\LabmetroOnline.pfx"></add>
		<add key="PASTA_CERT_ZIPS" value="c:\Inetpub\wwwroot\labmetroang.isq.pt\UPLOADS\CERTIFICADOS\ZIPS\" />
