		<!-- COMMANDTIME OUT DO SQLCMD USADO NO CODIGO-->
		<add key="CommandTimeOut" value="60" />

		<!-- CONNECTIONSTRING CYRSTAL REPORTS-->
		<add key="ServerName" value="CLDDEV02\SQLEXPRESS" />
