        //=================================================================================================
        //PREENCHIMENTO DA DROPDOWN EMPRESA ===============================================================
        //=================================================================================================
        private void fillEmpresas()
        {
            DATA.FacturaData f = new LabMetro.DATA.FacturaData();
            DataTable DT = f.DTListaEmpresasForFactura(this.cbBRE.Checked.ToString(), this.txtPesquisaEmpresa.Text, this.txtPesquisaNif.Text, this.txtPesquisaNumClienteSAP.Text);
            DataView DV = new DataView(DT);

            this.ddEmpresa.DataSource = DV;
            this.ddEmpresa.DataBind();

            f = null;

            this.fillEmpresaDevedora(); //da primeira vez
           
        }

        //===========================================================================================
        //PREENCHE OS DADOS RELATIVOS À EMPRESA e que tenham a ver com os DADOS DO SAP
        //se a factura é para ser emitida em nome de outra empresa, vai buscar os dados SAP da outra empresa
        //===========================================================================================
        private void fillEmpresaData_SAP()
        {
            string strSQL;

            string idEmpresa = this.ddEmpresa.SelectedValue;
            if (this.ddEmpresaContratante.SelectedValue != "") idEmpresa = this.ddEmpresaContratante.SelectedValue;


            if (idEmpresa != "")
            {

                //A REGIAO DE VENDAS É SEMPRE DA EMPRESA DO BRE, POIS SO SE APLICA EM CALIBRAÇÕES EXTERNAS E DIZ RESPEITO
                //À REGIÃO DA PRESTAÇÃO DO SERVIÇO

                strSQL = "SELECT E.observacoes, E.numClienteSAP, E.codigoBloqueioSap, E.idCondicoesPagamento, E.bPodeFacturarSemRequisicao FROM EMPRESA E  WHERE E.idEmpresa = " + idEmpresa;

                SqlDataReader dr = GERAL.clsDataAccess.ExecuteDR(strSQL);

                if (dr.HasRows)
                {
                    while (dr.Read())
                    {
                        this.lblObsEmpresa.Text = dr["observacoes"].ToString();
                        this.txtNumClienteSAP.Text = dr["numClienteSAP"].ToString();


                        try
                        {
                            string idCondicoesPagamento = dr["idCondicoesPagamento"].ToString();
                            this.ddCondPagamentoEmpresa.SelectedValue = idCondicoesPagamento;
                            if (this.ViewState["idFactura"] == null)
                            {
                                if (idCondicoesPagamento != "")
                                {
                                    this.ddCondPagamentoFactura.SelectedValue = this.ddCondPagamentoEmpresa.SelectedValue;
                                }
                                else
                                {
                                    this.ddCondPagamentoFactura.SelectedValue = "2"; //30 dias, default value; 
                                }
                            }
                        }
                        catch
                        { }


                        try
                        {
                            this.ddCodigoBloqueioSAP.SelectedValue = dr["codigoBloqueioSap"].ToString();
                        }
                        catch
                        { }


                        if (GERAL.clsGeral.ConvertBStringToBoolean(dr["bPodeFacturarSemRequisicao"].ToString()) == true)
                        {
                            this.cbNPrecisaReqPFacturar.Checked = true;

                        }
                        else
                        {
                            this.cbNPrecisaReqPFacturar.Checked = false;
                        }

                    }
                }
            }


            
        }

        //=================================================================================================
        // Preencher os dados relativos à empresa (se é devedora ou não)
        // isto futuramente pode ser merged com a forma como os dados da empresas são preenhcidos nas 
        // funções anteriores, mas por enquanto, never change a running system. 
        //=================================================================================================
        private void fillEmpresaDevedora()
        {
            //DM 05-12-2007

            this.lblEmpresaDevedora.Text = ""; //limpar a label

            string idEmpresa = this.ddEmpresa.SelectedValue;
            if (this.ddEmpresaContratante.SelectedValue != "")
            {
                idEmpresa = ddEmpresaContratante.SelectedValue;
                this.lblEmpresaDevedora.Text = "Empresa contratante: "; //limpar a label

            }
            this.lblEmpresaDevedora.Text = ""; //limpar a label

            LabMetro.DATA.EmpresasBD empresa = new LabMetro.DATA.EmpresasBD();
            LabMetro.DATA.CompanyDetails detEmpresa = empresa.GetCompanyDetails(idEmpresa);
            if (detEmpresa != null)
            {
                this.lblObsEmpresa.Text = detEmpresa.observacoes;    //meu

                if (detEmpresa.pagamentoAtraso == "1")
                {
                    this.lblEmpresaDevedora.Text += "** PAGAMENTOS EM ATRASO **<br>";
                }
                if (this.ddEmpresaContratante.SelectedValue != "")
                {

                    this.trEmpresa.BgColor = "";
                    switch (detEmpresa.nivelBloqueioLabmetro)
                    {
                        case "0":
                            this.trEmpresaContratante.BgColor = "";
                            break;
                        case "1":
                            this.trEmpresaContratante.BgColor = "Gold";
                            break;
                        case "2":
                            this.trEmpresaContratante.BgColor = "DarkOrange";
                            this.lblEmpresaDevedora.Text += "Venda à dinheiro ou Pagamento do Atrasado.<br>";
                            break;
                        case "3":
                            this.trEmpresaContratante.BgColor = "Crimson";
                            this.lblEmpresaDevedora.Text += "Venda à dinheiro.<br>";
                            break;
                    }
                }
                else
                {
                    this.trEmpresaContratante.BgColor = "";

                    switch (detEmpresa.nivelBloqueioLabmetro)
                    {
                        case "0":
                            this.trEmpresa.BgColor = "";
                            break;
                        case "1":
                            this.trEmpresa.BgColor = "Gold";
                            break;
                        case "2":
                            this.trEmpresa.BgColor = "DarkOrange";
                            this.lblEmpresaDevedora.Text += "Venda à dinheiro ou Pagamento do Atrasado.<br>";
                            break;
                        case "3":
                            this.trEmpresa.BgColor = "Crimson";
                            this.lblEmpresaDevedora.Text += "Venda à dinheiro.<br>";
                            break;
                    }
                }

                if (detEmpresa.codigoBloqueioSAP != "00")
                {
                    this.btnFicheiro.Enabled = false; //se empresa bloquada, nao pode criar ordens de venda
                    this.lblEmpresaDevedora.Text += "Criação de ordens de venda impossível.";
                }

                switch (detEmpresa.codigoBloqueioSAP)
                {
                    case "00":  //nada mas tem de estar tratado
                        break;
                    case "01":
                        this.lblEmpresaDevedora.Text += "** EMPRESA FALIDA **";
                        break;
                    case "02":
                        this.lblEmpresaDevedora.Text += "** EMPRESA EM CONTENCIOSO **";
                        break;
                    case "03":
                        this.lblEmpresaDevedora.Text += "** Empresa com nºCliente SAP inactivo **";
                        break;
                    default: //todos os outros bloqueados
                        this.lblEmpresaDevedora.Text += "** EMPRESA COM BLOQUEIO EM SAP **";
                        break;
                }
            }
            else//nada - limpar
            {
                this.lblEmpresaDevedora.Text = "";
                this.trEmpresa.BgColor = "";
                this.lblObsEmpresa.Text = "";

            }
            empresa = null;
        }

        
        //=================================================================================================
        //PREENCHIMENTO DA DROPDOWN BRES ==================================================================
        //=================================================================================================
        private void fillBREs()
        {
            if (this.ddEmpresa.SelectedIndex >= 0)
            {
                DATA.BreBD lista = new LabMetro.DATA.BreBD();
                DataTable DT = lista.DTGetBrePorFacturarByIdEmpresa(this.ddEmpresa.SelectedValue, this.cbBRE.Checked.ToString());
                this.ddBRE.DataSource = DT;
                this.ddBRE.DataBind();
                lista = null;
            }
            else
            {
                this.ddBRE.Items.Clear();
            }
        }


        //=================================================================================================
        //PREENCHIMENTO DA DROPDOWN BRES ==================================================================
        //=================================================================================================
        private void fillEmpresaContratanteDoBRE()
        {

            DATA.BreBD bre = new LabMetro.DATA.BreBD();

            SqlDataReader DR = bre.DRGetIdEmpresaContratantePorBRE(this.ddBRE.SelectedValue);
            ddEmpresaContratante.DataSource = DR;
