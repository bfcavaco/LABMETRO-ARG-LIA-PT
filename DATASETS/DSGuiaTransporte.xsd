<?xml version="1.0" encoding="utf-8" ?>
<xs:schema id="DSGuiaTransporte" targetNamespace="http://tempuri.org/DSGuiaTransporte.xsd"
	elementFormDefault="qualified" attributeFormDefault="qualified" xmlns="http://tempuri.org/DSGuiaTransporte.xsd"
	xmlns:mstns="http://tempuri.org/DSGuiaTransporte.xsd" xmlns:xs="http://www.w3.org/2001/XMLSchema"
	xmlns:msdata="urn:schemas-microsoft-com:xml-msdata">
	<xs:element name="DSGuiaTransporte" msdata:IsDataSet="true">
		<xs:complexType>
			<xs:choice maxOccurs="unbounded">
				<xs:element name="dtGuiaTransporte">
					<xs:complexType>
						<xs:sequence>
							<xs:element name="refGuiaTransporte" type="xs:string" />
							<xs:element name="idEmpresa" type="xs:int" />
							<xs:element name="localCarregamento" type="xs:string" />
							<xs:element name="localDescarregamento" type="xs:string" />
							<xs:element name="localDestino" type="xs:string" minOccurs="0" />
							<xs:element name="destinatario" type="xs:string" />
							<xs:element name="dataGuia" type="xs:dateTime" />
							<xs:element name="horaSaida" type="xs:string" minOccurs="0" />
							<xs:element name="horaChegada" type="xs:string" minOccurs="0" />
							<xs:element name="matricula" type="xs:string" minOccurs="0" />
							<xs:element name="nomeCondutor" type="xs:string" minOccurs="0" />
							<xs:element name="observacoes" type="xs:string" minOccurs="0" />
							<xs:element name="Funcionario" type="xs:string" minOccurs="0" />
							<xs:element name="numContribuinte" type="xs:string" minOccurs="0" />
						</xs:sequence>
					</xs:complexType>
				</xs:element>
				<xs:element name="dtServicosGuiaTransporte">
					<xs:complexType>
						<xs:sequence>
							<xs:element name="idGuiaTransporte" type="xs:int" />
							<xs:element name="idServico" msdata:ReadOnly="true" msdata:AutoIncrement="true" type="xs:int" />
							<xs:element name="idBRE" type="xs:int" minOccurs="0" />
							<xs:element name="refBRE" msdata:ReadOnly="true" type="xs:string" minOccurs="0" />
							<xs:element name="numIdentificacao" type="xs:string" minOccurs="0" />
							<xs:element name="numSerie" type="xs:string" minOccurs="0" />
							<xs:element name="codTipoEquipamento" type="xs:string" />
							<xs:element name="tipoEquipamento" type="xs:string" />
							<xs:element name="idEstadoServico" msdata:ReadOnly="true" msdata:AutoIncrement="true" type="xs:int" />
							<xs:element name="estadoServico" type="xs:string" />
							<xs:element name="idLocalCalibracao" type="xs:int" />
							<xs:element name="localCalibracao" type="xs:string" />
							<xs:element name="idTipoServico" type="xs:string" />
							<xs:element name="tipoServico" type="xs:string" />
							<xs:element name="refServico" type="xs:string" />
							<xs:element name="obsServico" type="xs:string" minOccurs="0" />
							<xs:element name="obsBRE" type="xs:string" minOccurs="0" />
						</xs:sequence>
					</xs:complexType>
				</xs:element>
			</xs:choice>
		</xs:complexType>
	</xs:element>
</xs:schema>