		<add key="CERT_PASSWORD" value="ISQ.Angola.2023#"></add>
		<add key="CERT_REASON" value="Documento aprovado electronicamente"></add>
		<add key="CERT_LOCATION" value="ISQ - LabMetro"></add>

		<add key="TEMPLATE_PAGINA" value="certif.pdf" />
		<add key="TEMPLATE_PAGINA_IPAC" value="certif_IPAC.pdf" />
